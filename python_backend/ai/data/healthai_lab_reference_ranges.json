{
  "lab_tests": {
    "Hemoglobin": {
      "name": "Hemoglobin",
      "unit": "g/dL",
      "normal_range": {
        "male": "13.5-17.5",
        "female": "12.0-15.5"
      },
      "description": "Protein in red blood cells that carries oxygen",
      "low_indicates": ["anemia", "blood loss", "bone marrow disorders"],
      "high_indicates": ["dehydration", "polycythemia", "lung disease"],
      "critical_low": 7.0,
      "critical_high": 20.0
